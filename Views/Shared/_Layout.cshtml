@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@{
    var isLoggedIn = SignInManager.IsSignedIn(User);
    var isAdmin = User.IsInRole("Admin");
    var isPro = User.IsInRole("Pro");
    var userName = User.Identity?.Name ?? "Guest";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Resuniq AI</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("PageStyles", required: false)
</head>
<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="brand-mark">
                <div class="brand-icon">RA</div>
                <div class="brand-copy">
                    <h1>Resuniq AI</h1>
                    <p>Smart career platform</p>
                </div>
            </div>

            <div class="side-section">
                <p class="side-section-label">Navigate</p>

                <a class="nav-link-pro" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i>
                    <span>Command Center</span>
                </a>

                @if (isLoggedIn)
                {
                    <a class="nav-link-pro" asp-controller="Resume" asp-action="Index">
                        <i class="bi bi-grid-1x2"></i>
                        <span>Resume Workspace</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Resume" asp-action="Create">
                        <i class="bi bi-file-earmark-plus"></i>
                        <span>Create Resume</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Profile" asp-action="Index">
                        <i class="bi bi-person-badge"></i>
                        <span>Profile Dashboard</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Templates" asp-action="Index">
                        <i class="bi bi-columns-gap"></i>
                        <span>All Templates</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Templates" asp-action="Ats">
                        <i class="bi bi-check2-square"></i>
                        <span>ATS Library</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Templates" asp-action="Premium">
                        <i class="bi bi-stars"></i>
                        <span>Premium Formats</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Features" asp-action="Toolkit">
                        <i class="bi bi-boxes"></i>
                        <span>Career Toolkit</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Features" asp-action="InterviewCoach">
                        <i class="bi bi-mic"></i>
                        <span>Interview Coach</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Features" asp-action="JobTracker">
                        <i class="bi bi-kanban"></i>
                        <span>Job Tracker</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Payment" asp-action="Upgrade">
                        <i class="bi bi-gem"></i>
                        <span>Upgrade Plan</span>
                    </a>
                }
            </div>

            @if (!isLoggedIn)
            {
                <div class="side-section">
                    <p class="side-section-label">Access</p>

                    <a class="nav-link-pro" href="/Identity/Account/Login">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Login</span>
                    </a>

                    <a class="nav-link-pro" href="/Identity/Account/Register">
                        <i class="bi bi-person-plus"></i>
                        <span>Register</span>
                    </a>
                </div>
            }
            else
            {
                <form class="logout-form"
                      asp-area="Identity"
                      asp-page="/Account/Logout"
                      asp-route-returnUrl="/"
                      method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light logout-btn">Logout</button>
                </form>
            }

            <div class="side-promo mt-4">
                <h3>18 Resume Formats</h3>
                <p>6 ATS-first templates and 12 premium layouts are ready for quick customization.</p>
                <a class="btn btn-brand w-100" asp-controller="Templates" asp-action="Index">Explore Library</a>
            </div>

            @if (isAdmin)
            {
                <div class="side-section mt-4">
                    <p class="side-section-label">Admin</p>

                    <a class="nav-link-pro" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-shield-check"></i>
                        <span>Admin Panel</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Admin" asp-action="Payments">
                        <i class="bi bi-credit-card-2-front"></i>
                        <span>Payments</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Admin" asp-action="Users">
                        <i class="bi bi-people"></i>
                        <span>Users</span>
                    </a>

                    <a class="nav-link-pro" asp-controller="Admin" asp-action="Jobs">
                        <i class="bi bi-briefcase"></i>
                        <span>Jobs</span>
                    </a>
                </div>
            }
        </aside>

        <main class="app-main">
            <div class="app-topbar">
                <div>
                    <h2>Welcome back, @userName</h2>
                    <p>Build stronger resumes, choose a format, and move faster from application to interview.</p>
                </div>

                <div class="topbar-stack">
                    @if (isAdmin)
                    {
                        <a class="btn btn-brand" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-shield-check"></i>
                            Admin Panel
                        </a>

                        <span class="status-pill free">
                            <i class="bi bi-shield-fill-check"></i>
                            Admin Access
                        </span>
                    }

                    <div class="topbar-actions">
                        @if (isPro)
                        {
                            <span class="status-pill pro">
                                <i class="bi bi-gem"></i>
                                Pro Plan
                            </span>
                        }
                        else
                        {
                            <span class="status-pill free">
                                <i class="bi bi-lightning-charge"></i>
                                Free Plan
                            </span>
                        }
                    </div>
                </div>
            </div>

            <div class="page-shell">
                @RenderBody()

                <footer class="app-footer">
                    <strong>Resuniq AI &copy; 2026 Created by Debodipto Samadder.</strong>
                </footer>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
