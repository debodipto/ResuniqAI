@model ResuniqAI.ViewModels.AdminJobsViewModel

@{
    ViewData["Title"] = "Manage Jobs";
}

<div class="d-grid gap-4">
    <section class="hero-panel">
        <span class="eyebrow">Admin Jobs</span>
        <h1 class="hero-title mt-3">Publish jobs here so users can see them from the Job Board page.</h1>
        <p class="hero-subtitle mt-3">This gives the admin panel a real publishing workflow and makes the user job tracker useful.</p>
    </section>

    <section class="builder-panel">
        <form asp-action="Jobs" method="post" class="form-grid">
            @Html.AntiForgeryToken()

            <div>
                <label asp-for="NewJob.Title" class="form-label">Job Title</label>
                <input asp-for="NewJob.Title" class="form-control" />
            </div>
            <div>
                <label asp-for="NewJob.CompanyName" class="form-label">Company Name</label>
                <input asp-for="NewJob.CompanyName" class="form-control" />
            </div>
            <div>
                <label asp-for="NewJob.Location" class="form-label">Location</label>
                <input asp-for="NewJob.Location" class="form-control" />
            </div>
            <div>
                <label asp-for="NewJob.EmploymentType" class="form-label">Employment Type</label>
                <input asp-for="NewJob.EmploymentType" class="form-control" />
            </div>
            <div class="field-full">
                <label asp-for="NewJob.SalaryRange" class="form-label">Salary Range</label>
                <input asp-for="NewJob.SalaryRange" class="form-control" />
            </div>
            <div class="field-full">
                <label asp-for="NewJob.Description" class="form-label">Description</label>
                <textarea asp-for="NewJob.Description" class="form-control" rows="5"></textarea>
            </div>
            <div class="field-full">
                <label asp-for="NewJob.Requirements" class="form-label">Requirements</label>
                <textarea asp-for="NewJob.Requirements" class="form-control" rows="5"></textarea>
            </div>
            <div class="field-full">
                <button type="submit" class="btn btn-brand">Publish Job</button>
            </div>
        </form>
    </section>

    <section class="builder-panel">
        <div class="section-heading">
            <div>
                <h2>Published Jobs</h2>
                <p>Toggle active status to show or hide jobs from users.</p>
            </div>
        </div>

        @if (Model.Jobs.Any())
        {
            <div class="template-grid">
                @foreach (var job in Model.Jobs)
                {
                    <article class="template-card">
                        <h3>@job.Title</h3>
                        <p class="muted-copy">@job.CompanyName</p>
                        <p class="muted-copy">@job.Location | @job.EmploymentType</p>
                        <p class="muted-copy">@job.SalaryRange</p>
                        <div class="page-note">@job.Description</div>
                        <p class="muted-copy mt-3">@job.Requirements</p>
                        <form asp-action="ToggleJob" method="post" class="mt-3">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@job.Id" />
                            <button class="btn @(job.IsActive ? "btn-soft" : "btn-brand")" type="submit">
                                @(job.IsActive ? "Hide Job" : "Show Job")
                            </button>
                        </form>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="list-panel text-center">
                <h3>No jobs published yet</h3>
            </div>
        }
    </section>
</div>
