@model IEnumerable<ResuniqAI.Models.Payment>

@{
    ViewData["Title"] = "Payments Dashboard";
    var payments = Model ?? Enumerable.Empty<ResuniqAI.Models.Payment>();
}

<style>
    body {
        background: #f3f4f6;
        font-family: 'Segoe UI', sans-serif;
    }

    .card-box {
        background: white;
        padding: 20px;
        border-radius: 14px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    .status-approved {
        color: green;
        font-weight: bold;
    }

    .status-pending {
        color: orange;
        font-weight: bold;
    }

    .btn-approve {
        border-radius: 8px;
        font-weight: 600;
    }
</style>

<div class="container mt-4">

    <h2>Payments Dashboard</h2>

    <div class="card-box mt-3">

        @if (payments.Any())
        {
            <div class="table-responsive-panel">
                <table class="table table-hover">

                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Transaction</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var p in payments)
                        {
                            <tr>
                                <td>@p.UserEmail</td>
                                <td>@p.TransactionId</td>

                                <td>
                                    @if (p.IsApproved)
                                    {
                                        <span class="status-approved">Approved</span>
                                    }
                                    else
                                    {
                                        <span class="status-pending">Pending</span>
                                    }
                                </td>

                                <td>
                                    @if (!p.IsApproved)
                                    {
                                        <form method="post" action="/Admin/Approve">
                                            <input type="hidden" name="id" value="@p.Id" />

                                            <button type="submit"
                                                    class="btn btn-success btn-sm btn-approve">
                                                Approve
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Done</span>
                                    }
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>
            </div>
        }
        else
        {
            <div class="text-center">
                <h5>No Payments Found</h5>
            </div>
        }

    </div>

</div>
