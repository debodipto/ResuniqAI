@model ResuniqAI.ViewModels.CareerToolkitViewModel

@{
    ViewData["Title"] = "Career Toolkit";
}

<div class="d-grid gap-4">
    <section class="hero-panel">
        <span class="eyebrow">Career Toolkit</span>
        <h1 class="hero-title mt-3">Create cover letters and analyze ATS match from an uploaded or pasted CV.</h1>
        <p class="hero-subtitle mt-3">This toolkit now works as an actual utility page instead of a static feature summary.</p>
    </section>

    <form asp-action="Toolkit" method="post" enctype="multipart/form-data" class="d-grid gap-4">
        @Html.AntiForgeryToken()

        <section class="builder-panel">
            <div class="form-grid">
                <div>
                    <label asp-for="CandidateName" class="form-label">Candidate Name</label>
                    <input asp-for="CandidateName" class="form-control" />
                </div>
                <div>
                    <label asp-for="TargetRole" class="form-label">Target Role</label>
                    <input asp-for="TargetRole" class="form-control" />
                </div>
                <div>
                    <label asp-for="CompanyName" class="form-label">Company Name</label>
                    <input asp-for="CompanyName" class="form-control" />
                </div>
                <div>
                    <label class="form-label">Upload CV File</label>
                    <input type="file" name="cvFile" class="form-control" />
                </div>
                <div class="field-full">
                    <label asp-for="ResumeText" class="form-label">CV Text</label>
                    <textarea asp-for="ResumeText" class="form-control" rows="8" placeholder="Paste CV content here if you are not uploading a text-based file."></textarea>
                </div>
                <div class="field-full">
                    <label asp-for="JobDescription" class="form-label">Job Description</label>
                    <textarea asp-for="JobDescription" class="form-control" rows="8" placeholder="Paste the target job description for ATS analysis."></textarea>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-3 mt-4">
                <button type="submit" name="command" value="cover-letter" class="btn btn-brand">Generate Cover Letter</button>
                <button type="submit" name="command" value="ats-score" class="btn btn-soft">Analyze ATS Score</button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.CoverLetterResult))
        {
            <section class="builder-panel">
                <h3>Cover Letter Result</h3>
                <textarea class="form-control mt-3" rows="12">@Model.CoverLetterResult</textarea>
            </section>
        }

        @if (Model.AtsScore > 0)
        {
            <section class="builder-panel">
                <div class="feature-grid">
                    <div class="feature-card">
                        <h3>ATS Score</h3>
                        <div class="kpi-number">@Model.AtsScore</div>
                    </div>
                    <div class="feature-card">
                        <h3>ATS Feedback</h3>
                        <p class="muted-copy" style="white-space:pre-wrap">@Model.AtsFeedback</p>
                    </div>
                </div>
            </section>
        }
    </form>
</div>
