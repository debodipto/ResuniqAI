@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: #0b1220;
        font-family: 'Segoe UI', sans-serif;
    }

    .auth-box {
        max-width: 420px;
        margin: 60px auto;
        background: #111827;
        padding: 30px;
        border-radius: 18px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.5);
        color: white;
    }

    .auth-title {
        text-align: center;
        margin-bottom: 20px;
        font-weight: 700;
        font-size: 26px;
    }

    .form-control {
        background: #1f2937;
        border: none;
        color: white;
        border-radius: 10px;
    }

    .form-control:focus {
        background: #1f2937;
        color: white;
        border: 1px solid #6366f1;
        box-shadow: none;
    }

    .btn-main {
        width: 100%;
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
    }
</style>

<div class="auth-box">

    <div class="auth-title">Create Account</div>

    <form method="post">

        <div class="mb-3">
            <label>Email</label>
            <input asp-for="Input.Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Password</label>
            <input asp-for="Input.Password" type="password" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Confirm Password</label>
            <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
        </div>

        <button type="submit" class="btn btn-success btn-main">
            Register
        </button>

        <div class="mt-3 text-center">
            <a asp-page="./Login">Already have account? Login</a>
        </div>

    </form>

</div>
